# Local development default. Set this to https://naadbackstage.com in production.
NUXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
NUXT_PUBLIC_INACTIVITY_TIMEOUT_MS=1800000
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_KEY=
NUXT_ADMIN_VERIFICATION_SECRET=
SUPABASE_SECRET_KEY=

# Resend transactional email. Keep this server-side only.
# The sender domain is currently auth.naadbackstage.com.
RESEND_API_KEY=
RESEND_FROM="Naad Backstage <noreply@auth.naadbackstage.com>"
RESEND_REPLY_TO=
EMAIL_LOGO_URL=
DASHBOARD_ADMIN_ALERT_EMAILS=
DASHBOARD_EMAILS_DISABLED=false

# Optional smoke-test overrides
SMOKE_BASE_URL=http://localhost:3100
SMOKE_ADMIN_EMAIL=smoke-admin@naad-backstage.local
SMOKE_ADMIN_PASSWORD=SmokeAdmin123!
SMOKE_ADMIN_FULL_NAME=Smoke Admin
SMOKE_ARTIST_EMAIL=smoke-artist@naad-backstage.local
SMOKE_ARTIST_PASSWORD=SmokeArtist123!
SMOKE_ARTIST_FULL_NAME=Smoke Artist
SMOKE_ARTIST_STAGE_NAME=Smoke Artist
SMOKE_ARTIST_COUNTRY=Nepal
SMOKE_ARTIST_BIO=Smoke test artist account
